{
  "$schema": "https://typedoc.org/schema.json",
  "plugin": ["typedoc-plugin-markdown"],
  "entryPoints": [
    "src/index.ts",
    "src/backends/indexeddb/index.ts",
    "src/backends/sqlite/index.ts",
    "src/backends/sql/index.ts",
    "src/backends/sql/PostgresBackend.ts",
    "src/backends/sql/MySqlBackend.ts",
    "src/backends/mongo/index.ts",
    "src/backends/decorators/index.ts",
    "src/sync/index.ts",
    "src/transport/index.ts",
    "src/compat/mongo.ts"
  ],
  "entryPointStrategy": "resolve",
  "tsconfig": "tsconfig.json",
  "out": "docs/api",
  "readme": "none",
  "githubPages": false,
  "hideGenerator": true,
  "outputFileStrategy": "modules",
  "mergeReadme": false,
  "excludeInternal": true,
  "excludePrivate": true,
  "sort": ["source-order"],
  "categorizeByGroup": true,
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": true
  }
}
